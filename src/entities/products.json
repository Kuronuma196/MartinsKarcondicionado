
{
  "name": "products",
  "options": {
    "validator": {
      "$jsonSchema": {
        "bsonType": "object",
        "required": ["name", "description", "price", "category", "brand", "inStock", "createdAt"],
        "properties": {
          "name": {
            "bsonType": "string",
            "description": "Nome do produto"
          },
          "description": {
            "bsonType": "string",
            "description": "Descrição do produto"
          },
          "price": {
            "bsonType": "number",
            "minimum": 0,
            "description": "Preço do produto"
          },
          "originalPrice": {
            "bsonType": "number",
            "minimum": 0,
            "description": "Preço original (para promoções)"
          },
          "category": {
            "bsonType": "string",
            "enum": ["ar-condicionado", "pecas", "acessorios", "ferramentas", "refrigeracao"],
            "description": "Categoria do produto"
          },
          "brand": {
            "bsonType": "string",
            "description": "Marca do produto"
          },
          "model": {
            "bsonType": "string",
            "description": "Modelo do produto"
          },
          "specifications": {
            "bsonType": "object",
            "description": "Especificações técnicas"
          },
          "inStock": {
            "bsonType": "bool",
            "description": "Se está em estoque"
          },
          "quantity": {
            "bsonType": "int",
            "minimum": 0,
            "description": "Quantidade em estoque"
          },
          "imageUrl": {
            "bsonType": "string",
            "description": "URL da imagem principal"
          },
          "images": {
            "bsonType": "array",
            "description": "Array de URLs de imagens"
          },
          "isPromoted": {
            "bsonType": "bool",
            "description": "Se está em promoção"
          },
          "rating": {
            "bsonType": "number",
            "minimum": 0,
            "maximum": 5,
            "description": "Avaliação do produto"
          },
          "creator": {
            "bsonType": "string",
            "description": "Criador do produto"
          },
          "createdAt": {
            "bsonType": "string",
            "title": "datetime",
            "description": "Data de criação"
          },
          "updatedAt": {
            "bsonType": "string",
            "title": "datetime",
            "description": "Data de atualização"
          }
        },
        "additionalProperties": true
      }
    },
    "validationLevel": "moderate",
    "validationAction": "warn"
  }
}
